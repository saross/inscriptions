# Zotero API credentials for the inscriptions project.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Never commit actual keys; rotate immediately if one is exposed.
#
# Key scope created for this project (2026-04-24):
#   - Read: all libraries (personal + SDAM group)
#   - Write: SDAM group library only (the "SPA" collection lives there)
#
# Generate / manage keys at https://www.zotero.org/settings/keys
# Look up library IDs at https://www.zotero.org/groups/ (member number in URL)

# The API key itself (read-everything, write-SDAM-only).
ZOTERO_API_KEY=

# SDAM group library numeric ID — the target for writes (new items,
# PDF attachments, notes) and for group-library reads via API.
ZOTERO_GROUP_ID=

# User library ID (optional — needed only if we later want API reads
# of the personal library; local SQLite covers most read needs).
ZOTERO_USER_ID=
